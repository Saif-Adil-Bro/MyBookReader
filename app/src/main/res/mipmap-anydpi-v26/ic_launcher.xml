<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon.
  Replace the actual PNG files in:
    mipmap-mdpi/ic_launcher.png       (48x48)
    mipmap-hdpi/ic_launcher.png       (72x72)
    mipmap-xhdpi/ic_launcher.png      (96x96)
    mipmap-xxhdpi/ic_launcher.png     (144x144)
    mipmap-xxxhdpi/ic_launcher.png    (192x192)

  And the round variants:
    mipmap-*/ic_launcher_round.png

  You can use Android Studio's Image Asset Studio:
  Right-click res → New → Image Asset → Launcher Icons (Adaptive and Legacy)

  Use the ic_splash_logo.xml vector as the foreground,
  and #064E3B (Emerald-950) as the background color.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_splash_logo" />
    <monochrome android:drawable="@drawable/ic_splash_logo" />
</adaptive-icon>
